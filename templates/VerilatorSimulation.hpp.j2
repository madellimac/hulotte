#ifndef VERILATORSIMULATION_HPP
#define VERILATORSIMULATION_HPP

#include <verilated.h>
#include <verilated_vcd_c.h>
#include <iostream>
#include <streampu.hpp>
#include <memory>
#include <mutex>

namespace spu
{
namespace module
{

// Global mutex to protect Verilator initialization from race conditions
// When Source_random and Finalizer modules are created before VerilatorSimulation,
// there's a race condition during Verilator object creation. This mutex serializes
// the initialization.
static std::mutex g_verilator_init_mutex;

/**
 * Templated Verilator simulation wrapper for generic hardware blocks
 * Works with any hardware block that implements the standard ready/valid interface
 * 
 * THREAD SAFETY:
 * - Uses global mutex to protect Verilator initialization from race conditions
 * - Handles StreamPU module cloning with _is_cloning flag to prevent recursive task creation
 * 
 * Usage:
 *    #include "VModel_increment.h"
 *    auto sim = std::make_unique<VerilatorSimulation<VModel_increment>>(frame_size);
 */
template<typename VModelT>
class VerilatorSimulation : public Stateful {

private:
    VModelT* dut = nullptr;
    VerilatedVcdC* m_trace = nullptr;
    VerilatedContext* m_context = nullptr;
    vluint64_t sim_time = 0;
    int frame_size;
    std::string trace_name;
    bool _is_cloning = false;  // Flag to prevent task creation during cloning
    
    bool is_reset_time() { return (sim_time < 3); }  // Reset for first 3 cycles instead of 7
    bool is_rising_edge() { return (sim_time % 2 == 0); }
    bool is_falling_edge() { return (sim_time % 2 != 0); }

public:
    VModelT* inst;

    // Main constructor - delegates to internal constructor
    VerilatorSimulation(int frame_size, const std::string& trace_name = "", bool enable_trace = true) 
    : VerilatorSimulation(frame_size, trace_name, enable_trace, false) {}
    
    // Internal constructor that allows control of _is_cloning
    // Pass is_cloning=true when called from clone() to skip task creation
    VerilatorSimulation(int frame_size, const std::string& trace_name, bool enable_trace, bool is_cloning) 
    : Stateful(), frame_size(frame_size), trace_name(trace_name), _is_cloning(is_cloning)
    {
        // Protect Verilator initialization from race conditions
        // This is necessary when VerilatorSimulation is created after Source_random
        {
            std::lock_guard<std::mutex> lock(g_verilator_init_mutex);
            
            // CRITICAL: Each hardware block gets its own dedicated VerilatedContext
            // This eliminates "same model already added" errors when multiple blocks coexist
            m_context = new VerilatedContext;
            m_context->traceEverOn(true);
            
            // Create the DUT in its dedicated context
            dut = new VModelT{m_context};
            inst = dut;
        }
        
        // Only create trace file for the main instance, not for clones
        if (enable_trace) {
            std::string final_trace_name = trace_name.empty() ? 
                std::string(typeid(VModelT).name()) + ".vcd" : trace_name + ".vcd";
            
            // Open VCD file manually before creating trace object
            m_trace = new VerilatedVcdC;
            
            // Try to open file - if it fails, disable tracing
            try {
                dut->trace(m_trace, 99);
                m_trace->open(final_trace_name.c_str());
            } catch (...) {
                // If opening fails, clean up and disable tracing
                delete m_trace;
                m_trace = nullptr;
            }
        } else {
            m_trace = nullptr;
        }
        
        this->set_name(typeid(VModelT).name());
        this->set_short_name(typeid(VModelT).name());
        
        // CRITICAL: Skip task creation if this is being called during clonability test
        // StreamPU's is_clonable() creates a temporary clone - we must not recursively create tasks
        if (!_is_cloning) {
            auto& t = this->create_task("simulate");
            auto p_in  = this->create_socket_in<int32_t>(t, "input", frame_size);
            auto p_out = this->create_socket_out<int32_t>(t, "output", frame_size);
            
            this->create_codelet(t, [p_in, p_out, this](Module &m, runtime::Task &t, const size_t frame_id) -> int {
                auto& mod = static_cast<VerilatorSimulation<VModelT>&>(m);
                auto* in_data = static_cast<int32_t*>(t[p_in].get_dataptr());
                auto* out_data = static_cast<int32_t*>(t[p_out].get_dataptr());
                mod.process_frame(in_data, out_data);
                return runtime::status_t::SUCCESS;
            });
        }
    }

    void process_frame(int32_t* in_data, int32_t* out_data) {
        // Phase 1: Reset (isolated phase)
        for (int rst = 0; rst < 2; rst++) {
            dut->clk = (sim_time % 2);  // Toggle clock
            dut->reset = 1;
            dut->in_valid = 0;
            dut->out_ready = 0;
            dut->in_data = 0;
            dut->eval();
            sim_time++;
            if (m_trace) {
                m_trace->dump(sim_time);
                m_trace->flush();
            }
        }
        
        // Phase 2: Data processing
        dut->reset = 0;
        
        for (int i = 0; i < frame_size; i++) {
            dut->clk = (sim_time % 2);  // Toggle clock
            // Control signals
            if (is_rising_edge()) {
                dut->in_data = in_data[i];
                dut->in_valid = 1;
                dut->out_ready = 1;
            } else {
                dut->in_valid = 0;
                dut->out_ready = 0;
            }
            
            dut->eval();
            
            // Capture output when valid
            if (dut->out_valid) {
                out_data[i] = dut->out_data;
            }
            
            sim_time++;
            if (m_trace) {
                m_trace->dump(sim_time);
                m_trace->flush();
            }
        }
    }

    virtual ~VerilatorSimulation() {
        if (m_trace) { m_trace->close(); delete m_trace; }
        if (dut) delete dut;
        // Clean up dedicated Verilator context
        if (m_context) delete m_context;
    }

    virtual VerilatorSimulation* clone() const override {
        // Clone without creating trace file to avoid duplicate VCD files
        // Pass true for is_cloning to skip task creation during the clone constructor
        auto cloned = new VerilatorSimulation(frame_size, "", false, true);
        cloned->deep_copy(*this);
        cloned->_is_cloning = false; // Unmark after cloning is complete
        return cloned;
    }
};

}
}

#endif
