{% else %}
#include <iostream>
#include <vector>
#include <memory>
#include <fstream>
#include <streampu.hpp>
{% if use_aff3ct %}
#include <aff3ct.hpp>
{% endif %}
{% if use_hw %}
// NOTE: Hardware block headers are added automatically by add_hardware_module.py
// Example: #include "VModel_increment.h"  // Generated by Verilator
#include "VerilatorSimulation.hpp"
#include "VModel_PassThrough.h"
{% endif %}
{% if use_custom %}
#include "custom/MyModule.hpp"
{% endif %}

using namespace spu;
using namespace spu::module;

int main(int argc, char** argv)
{
    std::cout << "Starting Hulotte project..." << std::endl;

{% if use_aff3ct %}
    // 1. Modules creation
    
    // RS(7, 5) => t=1, m=3. Bits 21 -> 15.
    // NOTE: This uses aff3ct B_32 (32-bit integer) template instantiation.
    const int N_rs = 7;  // Symbols
    const int K_rs = 5;  // Symbols
    const int m = 3;       // Bits per symbol
    const int t = (N_rs - K_rs) / 2; // Correction 
    const int N = N_rs * m; // Total bits
    const int K = K_rs * m; // Info bits

    module::Source_random<> source(K);
    module::Finalizer    <> finalizer(K);
    
    // Create RS Polynomial Generator (needed for RS construction)
    aff3ct::tools::RS_polynomial_generator poly(N_rs, t);
    
    // Create Encoder and Decoder
    aff3ct::module::Encoder_RS<>     encoder(K_rs, N_rs, poly);
    aff3ct::module::Decoder_RS_std<> decoder(K_rs, N_rs, poly);    

    {% if use_custom %}
    module::MyModule         my_module(K);
    {% endif %}
    {% if use_hw %}
    // NOTE: Only ONE Verilator instance can have tracing enabled due to Verilator context limitations
    // When adding new hardware modules with add_hardware_module.py, they are created with trace DISABLED
    module::VerilatorSimulation<VModel_PassThrough> verilator_sim(K, "trace_main", true);
    {% endif %}

    // 2. Sockets binding
    using namespace aff3ct::module;
    using namespace aff3ct::tools;
    
    // Chain construction
    {% if use_hw %}
    // Chain: Source -> PassThrough -> (Custom Module) -> Encoder
    source ["generate::out_data"] = verilator_sim["simulate::input"];
    {% if use_custom %}
    verilator_sim["simulate::output"] = my_module["process::in"];
    my_module["process::out"] = encoder[enc::tsk::encode][(int)enc::sck::encode::U_K];
    {% else %}
    verilator_sim["simulate::output"] = encoder[enc::tsk::encode][(int)enc::sck::encode::U_K];
    {% endif %}
    {% else %}
    // Chain: Source -> (Custom Module) -> Encoder
    source   [src::tsk::generate][(int)src::sck::generate::out_data] = 
    {% if use_custom %}
    my_module ["process::in"];
    my_module ["process::out"] = 
    {% endif %}
    encoder  [enc::tsk::encode][(int)enc::sck::encode::U_K];
    {% endif %}

    encoder  [enc::tsk::encode][(int)enc::sck::encode::X_N]        = decoder  [dec::tsk::decode_hiho][(int)dec::sck::decode_hiho::Y_N];
    decoder  [dec::tsk::decode_hiho][(int)dec::sck::decode_hiho::V_K] = finalizer["finalize::in"];

{% else %}
    // 1. Modules creation
    
    const int n_elmts = 16;
    module::Source_random<int> source(n_elmts);
    module::Finalizer  <int> finalizer(n_elmts);
    {% if use_custom %}
    module::MyModule         my_module(n_elmts);
    {% endif %}
    {% if use_hw %}
    // NOTE: Only ONE Verilator instance can have tracing enabled due to Verilator context limitations
    auto hw_passthrough = std::make_unique<VerilatorSimulation<VModel_PassThrough>>(n_elmts, "trace_main", true);
    
    // Additional hardware blocks can be added using add_hardware_module.py
    // They are created with trace DISABLED to avoid Verilator context conflicts
    // Example (add via script):
    //   #include "VModel_increment.h"
    //   auto hw_increment = std::make_unique<VerilatorSimulation<VModel_increment>>(n_elmts, "trace_increment", false);
    {% endif %}
    
    // 2. Sockets binding
    {% if use_hw %}
    // Default chain: Source -> PassThrough -> (Custom Module) -> Finalizer
    source  ["generate::out_data"] = (*hw_passthrough) ["simulate::input"];
    {% if use_custom %}
    (*hw_passthrough) ["simulate::output"] = my_module ["process::in"];
    my_module ["process::out"] = finalizer ["finalize::in"];
    {% else %}
    (*hw_passthrough) ["simulate::output"] = finalizer ["finalize::in"];
    {% endif %}
    
    // Additional hardware blocks can be connected here
    // Example: source["generate::out_data"] = (*hw_passthrough) ["simulate::input"];
    //          (*hw_passthrough) ["simulate::output"] = (*hw_increment) ["simulate::input"];
    //          (*hw_increment) ["simulate::output"] = finalizer["finalize::in"];
    {% elif use_custom %}
    // Chain: Source -> Custom Module -> Finalizer
    source  ["generate::out_data"] = my_module ["process::in"];
    my_module ["process::out"] = finalizer ["finalize::in"];
    {% else %}
    // Chain: Source -> Finalizer
    source  ["generate::out_data"] = finalizer["finalize::in"];
    {% endif %}
{% endif %}

    // 3. Sequence creation
    std::vector<runtime::Task*> first_tasks;
{% if use_aff3ct %}
    first_tasks.push_back(&source("generate"));
{% else %}
    first_tasks.push_back(&source("generate"));
{% endif %}

    runtime::Sequence sequence(first_tasks);

    // Configuration
    for (auto& type : sequence.get_tasks_per_types())
        for (auto& t : type)
        {
            t->set_stats(true);
            t->set_debug(false);
        }

    // 4. Execution
    std::cout << "Processing..." << std::endl;
    
    // Export dot file for visualization
    std::ofstream file("graph.dot");
    sequence.export_dot(file);

    // Run the sequence
    for (auto i = 0; i < 3; i++)
        sequence.exec_seq(); // Run 1 frame at a time

    // 5. Stats
    std::cout << "\\nEnd of execution." << std::endl;
    tools::Stats::show(sequence.get_tasks_per_types(), true, false);

    return 0;
}
{% endif %}
